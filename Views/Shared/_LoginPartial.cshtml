@using Microsoft.AspNetCore.Identity
@inject SignInManager<Uzytkownik> SignInManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <span class="nav-link text-dark">Witaj @User.Identity?.Name!</span>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-controller="Home" asp-action="Logout" method="post">
            <button type="submit" class="nav-link btn btn-link text-dark" style="border: none; background: none;">Wyloguj</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark" href="/Identity/Account/Register">Rejestracja</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" href="/Identity/Account/Login">Logowanie</a>
    </li>
}
</ul>