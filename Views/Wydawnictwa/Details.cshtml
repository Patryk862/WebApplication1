@model WebApplication1.Models.Wydawnictwo
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = "Szczegóły Wydawnictwa";
    
    // Szukamy użytkownika po jego ID
    var creator = Model.UserId != null ? await UserManager.FindByIdAsync(Model.UserId) : null;
    var creatorEmail = creator?.Email ?? "Nieznany użytkownik";
}

<h1>Szczegóły</h1>

<div>
    <h4>Wydawnictwo</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nazwa)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nazwa)
        </dd>
        
        <dt class="col-sm-2">
            Dodał(a)
        </dt>
        <dd class="col-sm-10 text-primary">
            @creatorEmail
        </dd>
    </dl>
</div>
<div class="mt-3">
    @if (User.Identity!.IsAuthenticated && Model.UserId == UserManager.GetUserId(User))
    {
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">Edytuj</a> @Html.Raw(" | ")
    }
    <a asp-action="Index" class="btn btn-secondary">Wróć do listy</a>
</div>